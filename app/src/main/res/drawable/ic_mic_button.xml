<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow ring -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#402196F3" />
            <size android:width="120dp" android:height="120dp" />
        </shape>
    </item>
    <!-- Inner circle -->
    <item android:left="10dp" android:top="10dp" android:right="10dp" android:bottom="10dp">
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#2196F3" />
            <solid android:color="#1A2196F3" />
        </shape>
    </item>
    <!-- Mic icon area -->
    <item android:left="35dp" android:top="35dp" android:right="35dp" android:bottom="35dp"
        android:drawable="@drawable/ic_mic" />
</layer-list>
